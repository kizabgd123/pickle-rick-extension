ample_weight\nfrom sklearn.preprocessing import TargetEncoder\nfrom scipy.special import softmax\nfrom scipy.stats import rankdata\nfrom pathlib import Path\nfrom itertools import combinations\nimport warnings\nwarnings.filterwarnings('ignore')\n\nSEED = 42\nN_FOLDS = 5\nORIG_ROW_WEIGHT = 0.35\nTE_CV = 3\n\ndef find_file(name, root='/kaggle/input'):\n    for r, d, f in os.walk(root):\n        if name in f:\n            return os.path.join(r, name)\n    return None\n\nLGBM_PARAMS = {\n    'n_estimators': 5000,\n    'learning_rate': 0.01,\n    'num_leaves': 511,\n    'min_child_samples': 30,\n    'subsample': 0.8,\n    'colsample_bytree': 0.4,\n    'reg_alpha': 0.5,\n    'reg_lambda': 0.5,\n    'random_state': SEED,\n    'verbose': -1,\n    'n_jobs': -1,\n    'num_class': 3,\n    'objective': 'multiclass',\n    'device': 'gpu',\n}\n\nXGB_PARAMS = {\n    'n_estimators': 4000,\n    'learning_rate': 0.01,\n    'max_depth': 12,\n    'subsample': 0.8,\n    'colsample_bytree': 0.4,\n    'random_state': SEED,\n    'n_jobs': -1,\n    'objective': 'multi:softprob',\n    'num_class': 3,\n    'tree_method': 'gpu_hist',\n    'grow_policy': 'lossguide',\n    'enable_categorical': True,\n}\n\nCB_PARAMS = {\n    'iterations': 4000,\n    'learning_rate': 0.01,\n    'depth': 8,\n    'l2_leaf_reg': 10,\n    'bootstrap_type': 'Bernoulli',\n    'subsample': 0.8,\n    'random_seed': SEED,\n    'loss_function': 'MultiClass',\n    'verbose': False,\n    'task_type': 'GPU',\n}","metadata":{"trusted":true,"id":"P06aeFmrMiKB","execution":{"iopub.status.busy":"2026-04-08T18:07:36.014689Z","iopub.execute_input":"2026-04-08T18:07:36.014953Z","iopub.status.idle":"2026-04-08T18:07:43.272367Z","shell.execute_reply.started":"2026-04-08T18:07:36.014926Z","shell.execute_reply":"2026-04-08T18:07:43.271459Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 3. Feature Engineering\nDeotte logits + Domain Features + Pairwise Interactions.\n","metadata":{"id":"2okyRPlqMiKC"}},{"cell_type":"code","source":"def get_logits(df):\n    soil_lt_25 = (df['Soil_Moisture'] < 25).astype(int)\n    temp_gt_30 = (df['Temperature_C'] > 30).astype(int)\n    rain_lt_300 = (df['Rainfall_mm'] < 300).astype(int)\n    wind_gt_10 = (df['Wind_Speed_kmh'] > 10).astype(int)\n    stage_flowering = (df['Crop_Growth_Stage'] == 'Flowering').astype(int)\n    stage_harvest = (df['Crop_Growth_Stage'] == 'Harvest').astype(int)\n    stage_sowing = (df['Crop_Growth_Stage'] == 'Sowing').astype(int)\n    stage_vegetative = (df['Crop_Growth_Stage'] == 'Vegetative').astype(int)\n    mulching_no = (df['Mulching_Used'] == 'No').astype(int)\n    mulching_yes = (df['Mulching_Used'] == 'Yes').astype(int)\n\n    logit_low = 16.3173 + (-11.0237 * soil_lt_25) + (-5.8559 * temp_gt_30) + (-10.8500 * rain_lt_300) + (-5.8284 * wind_gt_10) + (-5.4155 * stage_flowering) + (5.5073 * stage_harvest) + (5.2299 * stage_sowing) + (-5.4617 * stage_vegetative) + (-3.0014 * mulching_no) + (2.8613 * mulching_yes)\n    logit_med = 4.6524 + (0.3290 * soil_lt_25) + (-0.0204 * temp_gt_30) + (0.1542 * rain_lt_300) + (0.0841 * wind_gt_10) + (0.3586 * stage_flowering) + (-0.1348 * stage_harvest) + (-0.3547 * stage_sowing) + (0.3334 * stage_vegetative) + (0.1883 * mulching_no) + (0.0142 * mulching_yes)\n    logit_high = -20.9697 + (10.6947 * soil_lt_25) + (5.8763 * temp_gt_30) + (10.6958 * rain_lt_300) + (5.7444 * wind_gt_10) + (5.0569 * stage_flowering) + (-5.3725 * stage_harvest) + (-4.8752 * stage_sowing) + (5.1283 * stage_vegetative) + (2.8131 * mulching_no) + (-2.8755 * mulching_yes)\n\n    return np.stack([logit_low, logit_med, logit_high], axis=1)\n\ndef add_domain_features(df):\n    df = df.copy()\n    df['moisture_rain'] = df['Soil_Moisture'] * df['Rainfall_mm']\n    df['ET_proxy'] = df['Temperature_C'] * (100 - df['Humidity']) / 100.0\n    df['drying_force'] = df['Temperature_C'] * df['Wind_Speed_kmh']\n    df['water_deficit'] = (df['ET_proxy'] - df['Rainfall_mm']).clip(lower=0)\n\n    logits = get_logits(df)\n    df['deotte_logit_low'] = logits[:, 0]\n    df['deotte_logit_med'] = logits[:, 1]\n    df['deotte_logit_high'] = logits[:, 2]\n    return df\n\ndef train_model(model_type, X, y, X_test, sw, skf):\n    oof_probs = np.zeros((len(X), 3))\n    test_probs = np.zeros((len(X_test), 3))\n\n    for fold, (train_idx, val_idx) in enumerate(skf.split(X, y), 1):\n        X_tr, X_val = X.iloc[train_idx], X.iloc[val_idx]\n        y_tr, y_val = y[train_idx], y[val_idx]\n        w_tr = sw[train_idx]\n\n        te = TargetEncoder(cv=TE_CV, target_type='multiclass', random_state=SEED)\n        cat_cols = X_tr.select_dtypes(include=['object', 'category', 'int64']).columns.tolist()\n        cat_cols = [c for c in cat_cols if X_tr[c].nunique() < 100]\n\n        X_tr_te_arr = te.fit_transform(X_tr[cat_cols], y_tr)\n        X_val_te_arr = te.transform(X_val[cat_cols])\n        X_test_te_arr = te.transform(X_test[cat_cols])\n\n        te_cols = te.get_feature_names_out(cat_cols)\n        X_tr_te = pd.concat([X_tr.drop(columns=cat_cols), pd.DataFrame(X_tr_te_arr, columns=te_cols, index=X_tr.index)], axis=1)\n        X_val_te = pd.concat([X_val.drop(columns=cat_cols), pd.DataFrame(X_val_te_arr, columns=te_cols, index=X_val.index)], axis=1)\n        X_test_te = pd.concat([X_test.drop(columns=cat_cols), pd.DataFrame(X_test_te_arr, columns=te_cols, index=X_test.index)], axis=1)\n\n        if model_type == 'lgbm':\n            model = lgb.LGBMClassifier(**LGBM_PARAMS)\n            model.fit(X_tr_te, y_tr, eval_set=[(X_val_te, y_val)], sample_weight=w_tr, callbacks=[lgb.log_evaluation(100)])\n        elif model_type == 'xgb':\n            model = xgb.XGBClassifier(**XGB_PARAMS)\n            model.fit(X_tr_te, y_tr, eval_set=[(X_val_te, y_val)], sample_weight=w_tr, verbose=100)\n        elif model_type == 'catboost':\n            model = cb.CatBoostClassifier(**CB_PARAMS)\n            model.fit(X_tr_te, y_tr, eval_set=[(X_val_te, y_val)], sample_weight=w_tr)\n\n        oof_probs[val_idx] = model.predict_proba(X_val_te)\n        test_probs += model.predict_proba(X_test_te) / N_FOLDS\n        print(f'  Fold {fold} {model_type}: BA = {balanced_accuracy_score(y_val, oof_probs[val_idx].argmax(axis=1)):.5f}')\n\n    return oof_probs, test_probs","metadata":{"trusted":true,"id":"Tjbcb3e8MiKC","execution":{"iopub.status.busy":"2026-04-08T18:07:43.273917Z","iopub.execute_input":"2026-04-08T18:07:43.274836Z","iopub.status.idle":"2026-04-08T18:07:43.289725Z","shell.execute_reply.started":"2026-04-08T18:07:43.274809Z","shell.execute_reply":"2026-04-08T18:07:43.289073Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"!pip install -U xgboost","metadata":{"id":"85cecc46","outputId":"c6676511-d672-4a4b-c6ac-100b99818766","trusted":true,"execution":{"iopub.status.busy":"2026-04-08T18:07:43.290532Z","iopub.execute_input":"2026-04-08T18:07:43.290801Z","iopub.status.idle":"2026-04-08T18:07:46.75284Z","shell.execute_reply.started":"2026-04-08T18:07:43.29078Z","shell.execute_reply":"2026-04-08T18:07:46.752102Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def main():\n    train_path = find_file('train.csv')\n    test_path = find_file('test.csv')\n    orig_path = find_file('irrigation_prediction.csv')\n\n    print(f'Found data: {train_path}, {test_path}, {orig_path}')\n\n    train = pd.read_csv(train_path)\n    test = pd.read_csv(test_path)\n    orig = pd.read_csv(orig_path)\n\n    TARGET_MAP = {'Low': 0, 'Medium': 1, 'High': 2}\n    INV_TARGET_MAP = {0: 'Low', 1: 'Medium', 2: 'High'}\n\n    train['Irrigation_Need'] = train['Irrigation_Need'].map(TARGET_MAP)\n    orig['Irrigation_Need'] = orig['Irrigation_Need'].map(TARGET_MAP)\n\n    train = add_domain_features(train)\n    test = add_domain_features(test)\n    orig = add_domain_features(orig)\n\n    cat_cols = ['Soil_Type', 'Crop_Type', 'Crop_Growth_Stage', 'Season', 'Irrigation_Type', 'Water_Source', 'Region', 'Mulching_Used']\n    for col in cat_cols:\n        combined = pd.concat([train[col], test[col], orig[col]], axis=0)\n        mapper = {v: i for i, v in enumerate(combined.unique())}\n        train[col] = train[col].map(mapper)\n        test[col] = test[col].map(mapper)\n        orig[col] = orig[col].map(mapper)\n\n    train['ORIG_ROW'] = 0\n    orig['ORIG_ROW'] = 1\n    common_cols = list(set(train.columns) & set(orig.columns))\n    train = pd.concat([train, orig[common_cols]], axis=0, ignore_index=True)\n\n    X = train.drop(['id', 'Irrigation_Need', 'ORIG_ROW'], axis=1)\n    y = train['Irrigation_Need'].values\n    sw = compute_sample_weight('balanced', y)\n    sw = np.where(train['ORIG_ROW'] == 1, sw * ORIG_ROW_WEIGHT, sw)\n    X_test = test.drop(['id'], axis=1)\n\n    skf = StratifiedKFold(n_splits=N_FOLDS, shuffle=True, random_state=SEED)\n\n    print('Training LightGBM...')\n    oof_lgb, test_lgb = train_model('lgbm', X, y, X_test, sw, skf)\n\n    print('Training XGBoost...')\n    oof_xgb, test_xgb = train_model('xgb', X, y, X_test, sw, skf)\n\n    print('Training CatBoost...')\n    oof_cb, test_cb = train_model('catboost', X, y, X_test, sw, skf)\n\n    def rank_blend(probs_list, power=1.1):\n        blended = np.zeros_like(probs_list[0])\n        for probs in probs_list:\n            ranks = np.zeros_like(probs)\n            for i in range(3):\n                ranks[:, i] = rankdata(probs[:, i]) / len(probs)\n            blended += ranks ** power\n        return blended / blended.sum(axis=1, keepdims=True)\n\n    oof_final = rank_blend([oof_lgb, oof_xgb, oof_cb])\n    test_final = rank_blend([test_lgb, test_xgb, test_cb])\n\n    # Bias Tuning\n    eps = 1e-15\n    oof_log_odds = np.log(np.clip(oof_final, eps, 1-eps) / (1 - np.clip(oof_final, eps, 1-eps)))\n    biases = np.zeros(3)\n    best_ba = balanced_accuracy_score(y, oof_final.argmax(axis=1))\n    for _ in range(2000):\n        improved = False\n        for cls in range(3):\n            for direction in [1, -1]:\n                new_bias = biases[cls] + direction * 0.005\n                temp_biases = biases.copy(); temp_biases[cls] = new_bias\n                adj_probs = softmax(oof_log_odds + temp_biases, axis=1)\n                ba = balanced_accuracy_score(y, adj_probs.argmax(axis=1))\n                if ba > best_ba:\n                    best_ba = ba; biases[cls] = new_bias; improved = True\n        if not improved: break\n\n    test_log_odds = np.log(np.clip(test_final, eps, 1-eps) / (1 - np.clip(test_final, eps, 1-eps)))\n    test_preds = softmax(test_log_odds + biases, axis=1).argmax(axis=1)\n\n    pd.DataFrame({'id': test['id'], 'Irrigation_Need': [INV_TARGET_MAP[p] for p in test_preds]}).to_csv('submission.csv', index=False)\n    print(f'God-Machine finished. OOF BA: {best_ba:.5f}')\n\nmain()","metadata":{"trusted":true,"id":"PNlF6y0YMiKD","execution":{"iopub.status.busy":"2026-04-08T18:07:46.754758Z","iopub.execute_input":"2026-04-08T18:07:46.755025Z"}},"outputs":[],"execution_count":null}]}